APP_NAME=task-ai-manager
APP_ENV=development
APP_DEBUG=true
APP_CORS_ALLOW_ALL_DEV=true
API_PREFIX=/api
APP_HOST=0.0.0.0
APP_PORT=8010
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8010
FRONTEND_URL=http://localhost:5174
BACKEND_URL=http://localhost:8010

# ── Database ──────────────────────────────────────────────
DATABASE_URL=<YOUR_POSTGRES_POOLER_CONNECTION_STRING>
# Optional: direct non-pooled DB URL for migrations
DIRECT_DATABASE_URL=<YOUR_POSTGRES_DIRECT_CONNECTION_STRING>

# ── AI Provider Configuration ─────────────────────────────
# Set to false to disable ALL AI features. CRUD will still work.
AI_ENABLED=true

# Provider: openai | generic_openai_compatible | deepseek | mock | noop
AI_PROVIDER=deepseek

# Model name (examples: gpt-4.1-mini, deepseek-chat)
AI_MODEL=deepseek-chat

# Your API key (required for openai and generic providers)
AI_API_KEY=replace_me

# Base URL for generic_openai_compatible/deepseek providers
AI_BASE_URL=https://api.deepseek.com

# Optional Anthropic-style aliases (only if your deployment expects these names)
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_API_KEY=replace_me
ANTHROPIC_MODEL=deepseek-chat

# Timeout in seconds for AI requests
AI_TIMEOUT_SECONDS=30

# If true, when AI fails, summary/chat will fallback gracefully instead of erroring
AI_ALLOW_FALLBACK=true
