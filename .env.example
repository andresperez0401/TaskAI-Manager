# Backend
APP_NAME=task-ai-manager
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api
APP_HOST=0.0.0.0
APP_PORT=8010
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8010
DATABASE_URL=<YOUR_POSTGRES_CONNECTION_STRING>
DIRECT_DATABASE_URL=<YOUR_DIRECT_POSTGRES_CONNECTION_STRING>

# AI Provider
AI_ENABLED=true
AI_PROVIDER=deepseek
AI_API_KEY=replace_me
AI_BASE_URL=replace_me
AI_MODEL=replace_me
AI_TIMEOUT_SECONDS=30
AI_ALLOW_FALLBACK=true

# Optional Anthropic-style aliases (if needed by your deployment)
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_API_KEY=replace_me
ANTHROPIC_MODEL=deepseek-chat

# URLs
BACKEND_URL=http://localhost:8010
FRONTEND_URL=http://localhost:5174

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8010
