{
  "name": "task-manager-ai-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && pipenv run start",
    "dev:frontend": "cd frontend && npm run dev -- --host 0.0.0.0 --port 5174",
    "migrate": "cd backend && pipenv run migrate",
    "pipenv:shell": "cd backend && pipenv shell"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
